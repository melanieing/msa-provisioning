{# ────────────────────────────────────────────────────────────────────── #}
{# 'kubeadm init' 이 사용할 설정 파일의 Jinja2 템플릿.                    #}
{# master-init.yaml 이 변수 치환 후 /etc/kubernetes/kubeadm-config.yaml 로 #}
{# 저장하고, 'kubeadm init --config /etc/kubernetes/kubeadm-config.yaml'   #}
{# 형태로 사용.                                                            #}
{# ────────────────────────────────────────────────────────────────────── #}
apiVersion: kubeadm.k8s.io/v1beta3
kind: ClusterConfiguration
kubernetesVersion: v1.35.4
controlPlaneEndpoint: "{{ nlb_dns_name }}:6443"
networking:
  podSubnet: "192.168.0.0/16"
apiServer:
  certSANs:
    - "{{ nlb_dns_name }}"
    - "{{ ansible_default_ipv4.address }}"
---
apiVersion: kubelet.config.k8s.io/v1beta1
kind: KubeletConfiguration
cgroupDriver: systemd

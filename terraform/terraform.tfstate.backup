          "attributes": {
            "content": "[ap-northeast-2a-masters]\n10.0.2.242\n10.0.2.252\n\n[ap-northeast-2a-workers]\n10.0.2.93\n\n[main-master]\nmain-master ansible_host=10.0.4.158\n\n[ap-northeast-2b-workers]\n10.0.4.214\n10.0.4.219\n\n[ap-northeast-2a-masters:vars]\nansible_ssh_common_args='-o ProxyCommand=\"ssh -W %h:%p -q ec2-user@54.180.138.40 -i ~/.ssh/ktcloud-bastion-node-key\"'\n\n[ap-northeast-2a-workers:vars]\nansible_ssh_common_args='-o ProxyCommand=\"ssh -W %h:%p -q ec2-user@54.180.138.40 -i ~/.ssh/ktcloud-bastion-node-key\"'\n\n[main-master:vars]\nansible_ssh_common_args='-o ProxyCommand=\"ssh -W %h:%p -q ec2-user@15.165.9.63 -i ~/.ssh/ktcloud-bastion-node-key\"'\n\n[ap-northeast-2b-workers:vars]\nansible_ssh_common_args='-o ProxyCommand=\"ssh -W %h:%p -q ec2-user@15.165.9.63 -i ~/.ssh/ktcloud-bastion-node-key\"'\n\n[all:vars]\nansible_port=22\nansible_user=ec2-user\nansible_ssh_private_key_file=~/.ssh/ktcloud-bastion-node-key\nansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'\nnlb_dns_name=kt-cloud-nlb-5be2e909d39b4a77.elb.ap-northeast-2.amazonaws.com\ncontrol_plane_endpoint=\"kt-cloud-nlb-5be2e909d39b4a77.elb.ap-northeast-2.amazonaws.com:6443\"\nvpc_id=vpc-02750c42d3a9c6a68",
